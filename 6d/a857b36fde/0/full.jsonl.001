{"parentUuid":"1632fc07-4c01-4f5f-822a-2c8ba660c8d2","isSidechain":false,"type":"progress","data":{"message":{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ENDYPywwAxpdUKy4CJxRPJ","type":"tool_result","content":"     1→\"\"\"Matter entity base class.\"\"\"\n     2→\n     3→from __future__ import annotations\n     4→\n     5→from collections.abc import Callable, Coroutine\n     6→from dataclasses import dataclass\n     7→import functools\n     8→import logging\n     9→from typing import TYPE_CHECKING, Any, Concatenate, cast\n    10→\n    11→from chip.clusters import Objects as clusters\n    12→from chip.clusters.Objects import ClusterAttributeDescriptor, ClusterCommand, NullValue\n    13→from matter_server.common.errors import MatterError\n    14→from matter_server.common.helpers.util import (\n    15→    create_attribute_path,\n    16→    create_attribute_path_from_attribute,\n    17→)\n    18→from matter_server.common.models import EventType, ServerInfoMessage\n    19→from propcache.api import cached_property\n    20→\n    21→from homeassistant.core import callback\n    22→from homeassistant.exceptions import HomeAssistantError\n    23→from homeassistant.helpers import entity_registry as er\n    24→from homeassistant.helpers.device_registry import DeviceInfo\n    25→from homeassistant.helpers.entity import Entity, EntityDescription\n    26→from homeassistant.helpers.typing import UndefinedType\n    27→\n    28→from .const import DOMAIN, FEATUREMAP_ATTRIBUTE_ID, ID_TYPE_DEVICE_ID\n    29→from .helpers import get_device_id\n    30→\n    31→if TYPE_CHECKING:\n    32→    from matter_server.client import MatterClient\n    33→    from matter_server.client.models.node import MatterEndpoint\n    34→\n    35→    from .discovery import MatterEntityInfo\n    36→\n    37→LOGGER = logging.getLogger(__name__)\n    38→\n    39→# Due to variances in labeling implementations, labels are vendor and product specific.\n    40→# This dictionary defines which labels to use for specific vendor/product combinations.\n    41→# The keys are vendor IDs, the values are dictionaries with product IDs as keys\n    42→# and lists of label names to use as values. If the value is None, no labels are used\n    43→VENDOR_LABELING_LIST: dict[int, dict[int, list[str] | None]] = {\n    44→    4488: {259: [\"position\"]},  # TP-Link Dual Outdoor Plug US\n    45→    4874: {105: [\"orientation\"]},  # Eve Energy dual Outlet US\n    46→    4961: {\n    47→        1: [\"inovelliname\", \"label\", \"name\", \"button\"],  # Inovelli VTM31\n    48→        2: [\"label\", \"devicetype\", \"button\"],  # Inovelli VTM35\n    49→        4: None,  # Inovelli VTM36\n    50→        16: [\"label\", \"name\", \"button\"],  # Inovelli VTM30\n    51→    },\n    52→}\n    53→\n    54→\n    55→def catch_matter_error[_R, **P](\n    56→    func: Callable[Concatenate[MatterEntity, P], Coroutine[Any, Any, _R]],\n    57→) -> Callable[Concatenate[MatterEntity, P], Coroutine[Any, Any, _R]]:\n    58→    \"\"\"Catch Matter errors and convert to Home Assistant error.\"\"\"\n    59→\n    60→    @functools.wraps(func)\n    61→    async def wrapper(self: MatterEntity, *args: P.args, **kwargs: P.kwargs) -> _R:\n    62→        \"\"\"Catch Matter errors and convert to Home Assistant error.\"\"\"\n    63→        try:\n    64→            return await func(self, *args, **kwargs)\n    65→        except MatterError as err:\n    66→            error_msg = str(err) or err.__class__.__name__\n    67→            raise HomeAssistantError(error_msg) from err\n    68→\n    69→    return wrapper\n    70→\n    71→\n    72→@dataclass(frozen=True, kw_only=True)\n    73→class MatterEntityDescription(EntityDescription):\n    74→    \"\"\"Describe the Matter entity.\"\"\"\n    75→\n    76→    # convert the value from the primary attribute to the value used by HA\n    77→    device_to_ha: Callable[[Any], Any] | None = None\n    78→    ha_to_device: Callable[[Any], Any] | None = None\n    79→    command_timeout: int | None = None\n    80→\n    81→\n    82→class MatterEntity(Entity):\n    83→    \"\"\"Entity class for Matter devices.\"\"\"\n    84→\n    85→    _attr_has_entity_name = True\n    86→    _attr_should_poll = False\n    87→    _name_postfix: str | None = None\n    88→    _platform_translation_key: str | None = None\n    89→\n    90→    def __init__(\n    91→        self,\n    92→        matter_client: MatterClient,\n    93→        endpoint: MatterEndpoint,\n    94→        entity_info: MatterEntityInfo,\n    95→    ) -> None:\n    96→        \"\"\"Initialize the entity.\"\"\"\n    97→        self.matter_client = matter_client\n    98→        self._endpoint = endpoint\n    99→        self._entity_info = entity_info\n   100→        self.entity_description = entity_info.entity_description\n   101→        self._unsubscribes: list[Callable] = []\n   102→        # for fast lookups we create a mapping to the attribute paths\n   103→        self._attributes_map: dict[type, str] = {}\n   104→        # The server info is set when the client connects to the server.\n   105→        server_info = cast(ServerInfoMessage, self.matter_client.server_info)\n   106→        # create unique_id based on \"Operational Instance Name\" and endpoint/device type\n   107→        node_device_id = get_device_id(server_info, endpoint)\n   108→        self._attr_unique_id = (\n   109→            f\"{node_device_id}-\"\n   110→            f\"{endpoint.endpoint_id}-\"\n   111→            f\"{entity_info.entity_description.key}-\"\n   112→            f\"{entity_info.primary_attribute.cluster_id}-\"\n   113→            f\"{entity_info.primary_attribute.attribute_id}\"\n   114→        )\n   115→        self._attr_device_info = DeviceInfo(\n   116→            identifiers={(DOMAIN, f\"{ID_TYPE_DEVICE_ID}_{node_device_id}\")}\n   117→        )\n   118→        self._attr_available = self._endpoint.node.available\n   119→        # mark endpoint postfix if the device has the primary attribute on multiple endpoints\n   120→        if not self._endpoint.node.is_bridge_device and any(\n   121→            ep\n   122→            for ep in self._endpoint.node.endpoints.values()\n   123→            if ep != self._endpoint\n   124→            and ep.has_attribute(None, entity_info.primary_attribute)\n   125→        ):\n   126→            self._name_postfix = str(self._endpoint.endpoint_id)\n   127→            if self._platform_translation_key and not self.translation_key:\n   128→                self._attr_translation_key = self._platform_translation_key\n   129→\n   130→        # Matter labels can be used to modify the entity name\n   131→        # by appending the text.\n   132→        if name_modifier := self._get_name_modifier():\n   133→            self._name_postfix = name_modifier\n   134→\n   135→        # make sure to update the attributes once\n   136→        self._update_from_device()\n   137→\n   138→    def _find_matching_labels(self) -> list[str]:\n   139→        \"\"\"Find all labels for a Matter entity.\"\"\"\n   140→\n   141→        device_info = self._endpoint.device_info\n   142→        labeling_list = VENDOR_LABELING_LIST.get(device_info.vendorID, {}).get(\n   143→            device_info.productID\n   144→        )\n   145→\n   146→        # get the labels from the UserLabel and FixedLabel clusters\n   147→        user_label_list: list[clusters.UserLabel.Structs.LabelStruct] = (\n   148→            self.get_matter_attribute_value(clusters.UserLabel.Attributes.LabelList)\n   149→            or []\n   150→        )\n   151→        fixed_label_list: list[clusters.FixedLabel.Structs.LabelStruct] = (\n   152→            self.get_matter_attribute_value(clusters.FixedLabel.Attributes.LabelList)\n   153→            or []\n   154→        )\n   155→\n   156→        found_labels: list[str] = [\n   157→            lbl.value\n   158→            for label in labeling_list or []\n   159→            for lbl in (*user_label_list, *fixed_label_list)\n   160→            if lbl.label.lower() == label\n   161→        ]\n   162→        return found_labels\n   163→\n   164→    def _get_name_modifier(self) -> str | None:\n   165→        \"\"\"Get the name modifier for the entity.\"\"\"\n   166→\n   167→        if found_labels := self._find_matching_labels():\n   168→            return found_labels[0]\n   169→        return None\n   170→\n   171→    async def async_added_to_hass(self) -> None:\n   172→        \"\"\"Handle being added to Home Assistant.\"\"\"\n   173→        await super().async_added_to_hass()\n   174→\n   175→        # Subscribe to attribute updates.\n   176→        sub_paths: list[str] = []\n   177→        for attr_cls in self._entity_info.attributes_to_watch:\n   178→            attr_path = self.get_matter_attribute_path(attr_cls)\n   179→            if attr_path in sub_paths:\n   180→                # prevent duplicate subscriptions\n   181→                continue\n   182→            self._attributes_map[attr_cls] = attr_path\n   183→            sub_paths.append(attr_path)\n   184→            self._unsubscribes.append(\n   185→                self.matter_client.subscribe_events(\n   186→                    callback=self._on_matter_event,\n   187→                    event_filter=EventType.ATTRIBUTE_UPDATED,\n   188→                    node_filter=self._endpoint.node.node_id,\n   189→                    attr_path_filter=attr_path,\n   190→                )\n   191→            )\n   192→        # subscribe to node (availability changes)\n   193→        self._unsubscribes.append(\n   194→            self.matter_client.subscribe_events(\n   195→                callback=self._on_matter_event,\n   196→                event_filter=EventType.NODE_UPDATED,\n   197→                node_filter=self._endpoint.node.node_id,\n   198→            )\n   199→        )\n   200→        # subscribe to FeatureMap attribute (as that can dynamically change)\n   201→        self._unsubscribes.append(\n   202→            self.matter_client.subscribe_events(\n   203→                callback=self._on_featuremap_update,\n   204→                event_filter=EventType.ATTRIBUTE_UPDATED,\n   205→                node_filter=self._endpoint.node.node_id,\n   206→                attr_path_filter=create_attribute_path(\n   207→                    endpoint=self._endpoint.endpoint_id,\n   208→                    cluster_id=self._entity_info.primary_attribute.cluster_id,\n   209→                    attribute_id=FEATUREMAP_ATTRIBUTE_ID,\n   210→                ),\n   211→            )\n   212→        )\n   213→\n   214→    @cached_property\n   215→    def name(self) -> str | UndefinedType | None:\n   216→        \"\"\"Return the name of the entity.\"\"\"\n   217→        if hasattr(self, \"_attr_name\"):\n   218→            # an explicit entity name was defined, we use that\n   219→            return self._attr_name\n   220→        name = super().name\n   221→        if name and self._name_postfix:\n   222→            name = f\"{name} ({self._name_postfix})\"\n   223→        return name\n   224→\n   225→    @callback\n   226→    def _on_matter_event(self, event: EventType, data: Any = None) -> None:\n   227→        \"\"\"Call on update from the device.\"\"\"\n   228→        self._attr_available = self._endpoint.node.available\n   229→        self._update_from_device()\n   230→        self.async_write_ha_state()\n   231→\n   232→    @callback\n   233→    def _on_featuremap_update(\n   234→        self, event: EventType, data: tuple[int, str, int] | None\n   235→    ) -> None:\n   236→        \"\"\"Handle FeatureMap attribute updates.\"\"\"\n   237→        if data is None:\n   238→            return\n   239→        new_value = data[2]\n   240→        # handle edge case where a Feature is removed from a cluster\n   241→        if (\n   242→            self._entity_info.discovery_schema.featuremap_contains is not None\n   243→            and not bool(\n   244→                new_value & self._entity_info.discovery_schema.featuremap_contains\n   245→            )\n   246→        ):\n   247→            # this entity is no longer supported by the device\n   248→            ent_reg = er.async_get(self.hass)\n   249→            ent_reg.async_remove(self.entity_id)\n   250→\n   251→            return\n   252→        # all other cases, just update the entity\n   253→        self._on_matter_event(event, data)\n   254→\n   255→    @callback\n   256→    def _update_from_device(self) -> None:\n   257→        \"\"\"Update data from Matter device.\"\"\"\n   258→\n   259→    @callback\n   260→    def get_matter_attribute_value(\n   261→        self, attribute: type[ClusterAttributeDescriptor], null_as_none: bool = True\n   262→    ) -> Any:\n   263→        \"\"\"Get current value for given attribute.\"\"\"\n   264→        value = self._endpoint.get_attribute_value(None, attribute)\n   265→        if null_as_none and value == NullValue:\n   266→            return None\n   267→        return value\n   268→\n   269→    @callback\n   270→    def get_matter_attribute_path(\n   271→        self, attribute: type[ClusterAttributeDescriptor]\n   272→    ) -> str:\n   273→        \"\"\"Return AttributePath by providing the endpoint and Attribute class.\"\"\"\n   274→        return create_attribute_path(\n   275→            self._endpoint.endpoint_id, attribute.cluster_id, attribute.attribute_id\n   276→        )\n   277→\n   278→    @catch_matter_error\n   279→    async def send_device_command(\n   280→        self,\n   281→        command: ClusterCommand,\n   282→        **kwargs: Any,\n   283→    ) -> None:\n   284→        \"\"\"Send device command on the primary attribute's endpoint.\"\"\"\n   285→        await self.matter_client.send_device_command(\n   286→            node_id=self._endpoint.node.node_id,\n   287→            endpoint_id=self._endpoint.endpoint_id,\n   288→            command=command,\n   289→            **kwargs,\n   290→        )\n   291→\n   292→    @catch_matter_error\n   293→    async def write_attribute(\n   294→        self,\n   295→        value: Any,\n   296→        matter_attribute: type[ClusterAttributeDescriptor] | None = None,\n   297→    ) -> Any:\n   298→        \"\"\"Write an attribute(value) on the primary endpoint.\n   299→\n   300→        If matter_attribute is not provided, the primary attribute of the entity is used."}]},"uuid":"494c1616-d4c8-40d8-a076-503c0674bc88","timestamp":"2026-04-05T04:28:31.461Z"},"type":"agent_progress","prompt":"","agentId":"a8cfb461256633736"},"toolUseID":"agent_msg_0162hX3uehmwnogfj3FQYhXY","parentToolUseID":"toolu_01G6sAuwJzUhPn9wBmY6dvqS","uuid":"abbbfa89-1a93-4ba7-baa3-c60d1a179283","timestamp":"2026-04-05T04:28:31.461Z","userType":"external","entrypoint":"cli","cwd":"/Users/raman/projects/lock_code_manager","sessionId":"3f097ff1-5bb6-4622-8cfe-35782dd270ba","version":"2.1.81","gitBranch":"fix/matter-duplicate-code-handling","slug":"jolly-wandering-moonbeam"}
