\n                if cred_index is None:","numLines":40,"startLine":348,"totalLines":481}},"sourceToolAssistantUUID":"08d286a8-72ef-4029-8cca-4150324ebbb7","userType":"external","entrypoint":"cli","cwd":"/Users/raman/projects/lock_code_manager","sessionId":"3f097ff1-5bb6-4622-8cfe-35782dd270ba","version":"2.1.81","gitBranch":"feat/lock-reset-step","slug":"jolly-wandering-moonbeam"}
