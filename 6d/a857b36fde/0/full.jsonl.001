{"parentUuid":"64562fef-d2c7-4a51-95c2-8bb3aefe9cff","isSidechain":false,"type":"progress","data":{"message":{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Mh6rsBqRVtWbfEmxP2Bz7P","type":"tool_result","content":"/Users/raman/.claude/shell-snapshots/snapshot-bash-1775143734045-fw9p9j.sh: line 372: alias: --: not found\n687:    @api_command(APICommand.DEVICE_COMMAND)\n688:    async def send_device_command(\n707:                \"send_device_command called for test node %s on endpoint_id: %s - \"","is_error":false}]},"uuid":"d10168c7-4ad7-4ba6-bcd9-7b4422a3d895","timestamp":"2026-04-05T04:28:45.665Z"},"type":"agent_progress","prompt":"","agentId":"a8cfb461256633736"},"toolUseID":"agent_msg_0162hX3uehmwnogfj3FQYhXY","parentToolUseID":"toolu_01G6sAuwJzUhPn9wBmY6dvqS","uuid":"645dae8d-990d-47c5-9533-a7695f78e18f","timestamp":"2026-04-05T04:28:45.665Z","userType":"external","entrypoint":"cli","cwd":"/Users/raman/projects/lock_code_manager","sessionId":"3f097ff1-5bb6-4622-8cfe-35782dd270ba","version":"2.1.81","gitBranch":"fix/matter-duplicate-code-handling","slug":"jolly-wandering-moonbeam"}
{"parentUuid":"645dae8d-990d-47c5-9533-a7695f78e18f","isSidechain":false,"type":"progress","data":{"message":{"type":"assistant","timestamp":"2026-04-05T04:28:47.323Z","message":{"model":"claude-haiku-4-5-20251001","id":"msg_017UjXvQSesYVeKfamG6GzM1","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01XzKk5inPgUkUNJVfAvzT5a","name":"Read","input":{"file_path":"/Users/raman/projects/lock_code_manager/.venv/lib/python3.13/site-packages/matter_server/server/device_controller.py","limit":800},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":0,"cache_creation_input_tokens":379,"cache_read_input_tokens":99849,"cache_creation":{"ephemeral_5m_input_tokens":379,"ephemeral_1h_input_tokens":0},"output_tokens":53,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"requestId":"req_011CZjzavMVpPWSdNRK7BFQ6","uuid":"37aece70-0b22-42ef-a602-1c2061e80e10"},"type":"agent_progress","prompt":"","agentId":"a8cfb461256633736"},"toolUseID":"agent_msg_0162hX3uehmwnogfj3FQYhXY","parentToolUseID":"toolu_01G6sAuwJzUhPn9wBmY6dvqS","uuid":"14f60fe5-5b3a-4fc9-ac87-caeb82f27c2c","timestamp":"2026-04-05T04:28:47.323Z","userType":"external","entrypoint":"cli","cwd":"/Users/raman/projects/lock_code_manager","sessionId":"3f097ff1-5bb6-4622-8cfe-35782dd270ba","version":"2.1.81","gitBranch":"fix/matter-duplicate-code-handling","slug":"jolly-wandering-moonbeam"}
{"parentUuid":"14f60fe5-5b3a-4fc9-ac87-caeb82f27c2c","isSidechain":false,"type":"progress","data":{"message":{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XzKk5inPgUkUNJVfAvzT5a","type":"tool_result","content":"     1→\"\"\"Matter Device Controller implementation.\n     2→\n     3→This module implements the Matter Device Controller WebSocket API. Compared to the\n     4→`ChipDeviceControllerWrapper` class it adds the WebSocket specific sauce and adds more\n     5→features which are not part of the Python Matter Device Controller per-se, e.g.\n     6→pinging a device.\n     7→\"\"\"\n     8→\n     9→from __future__ import annotations\n    10→\n    11→import asyncio\n    12→from collections import deque\n    13→from datetime import datetime\n    14→from functools import cached_property, lru_cache\n    15→import logging\n    16→import re\n    17→import secrets\n    18→import time\n    19→from typing import TYPE_CHECKING, Any, cast\n    20→\n    21→from chip.ChipDeviceCtrl import ChipDeviceController\n    22→from chip.clusters import Attribute, Objects as Clusters\n    23→from chip.clusters.Attribute import AttributeWriteResult, ValueDecodeFailure\n    24→from chip.clusters.ClusterObjects import ALL_ATTRIBUTES, ALL_CLUSTERS, Cluster\n    25→from chip.discovery import DiscoveryType\n    26→from chip.exceptions import ChipStackError\n    27→from chip.native import PyChipError\n    28→from zeroconf import (\n    29→    BadTypeInNameException,\n    30→    DNSQuestionType,\n    31→    IPVersion,\n    32→    ServiceStateChange,\n    33→    Zeroconf,\n    34→)\n    35→from zeroconf.asyncio import AsyncServiceBrowser, AsyncServiceInfo, AsyncZeroconf\n    36→\n    37→from matter_server.common.const import VERBOSE_LOG_LEVEL\n    38→from matter_server.common.custom_clusters import check_polled_attributes\n    39→from matter_server.common.models import (\n    40→    CommissionableNodeData,\n    41→    CommissioningParameters,\n    42→    MatterSoftwareVersion,\n    43→)\n    44→from matter_server.server.helpers.attributes import parse_attributes_from_read_result\n    45→from matter_server.server.helpers.utils import ping_ip\n    46→from matter_server.server.ota import check_for_update, load_local_updates\n    47→from matter_server.server.ota.provider import ExternalOtaProvider\n    48→from matter_server.server.sdk import ChipDeviceControllerWrapper\n    49→\n    50→from ..common.errors import (\n    51→    InvalidArguments,\n    52→    NodeCommissionFailed,\n    53→    NodeInterviewFailed,\n    54→    NodeNotExists,\n    55→    NodeNotReady,\n    56→    NodeNotResolving,\n    57→    UpdateCheckError,\n    58→    UpdateError,\n    59→)\n    60→from ..common.helpers.api import api_command\n    61→from ..common.helpers.json import JSON_DECODE_EXCEPTIONS, json_loads\n    62→from ..common.helpers.util import (\n    63→    create_attribute_path_from_attribute,\n    64→    dataclass_from_dict,\n    65→    parse_attribute_path,\n    66→    parse_value,\n    67→)\n    68→from ..common.models import (\n    69→    APICommand,\n    70→    EventType,\n    71→    MatterNodeData,\n    72→    MatterNodeEvent,\n    73→    NodePingResult,\n    74→    UpdateSource,\n    75→)\n    76→from .const import DATA_MODEL_SCHEMA_VERSION\n    77→\n    78→if TYPE_CHECKING:\n    79→    from collections.abc import Callable, Iterable\n    80→    from pathlib import Path\n    81→\n    82→    from .server import MatterServer\n    83→\n    84→DATA_KEY_NODES = \"nodes\"\n    85→DATA_KEY_LAST_NODE_ID = \"last_node_id\"\n    86→\n    87→LOGGER = logging.getLogger(__name__)\n    88→NODE_SUBSCRIPTION_FLOOR_DEFAULT = 1\n    89→NODE_SUBSCRIPTION_FLOOR_ICD = 0\n    90→NODE_SUBSCRIPTION_CEILING_WIFI = 60\n    91→NODE_SUBSCRIPTION_CEILING_THREAD = 60\n    92→NODE_SUBSCRIPTION_CEILING_BATTERY_POWERED = 600\n    93→NODE_RESUBSCRIBE_ATTEMPTS_UNAVAILABLE = 2\n    94→NODE_RESUBSCRIBE_TIMEOUT_OFFLINE = 30 * 60\n    95→NODE_RESUBSCRIBE_FORCE_TIMEOUT = 5\n    96→NODE_PING_TIMEOUT = 10\n    97→NODE_PING_TIMEOUT_BATTERY_POWERED = 60\n    98→NODE_MDNS_SUBSCRIPTION_RETRY_TIMEOUT = 30 * 60\n    99→CUSTOM_ATTRIBUTES_POLLER_INTERVAL = 30\n   100→\n   101→MDNS_TYPE_OPERATIONAL_NODE = \"_matter._tcp.local.\"\n   102→MDNS_TYPE_COMMISSIONABLE_NODE = \"_matterc._udp.local.\"\n   103→\n   104→TEST_NODE_START = 900000\n   105→\n   106→ROUTING_ROLE_ATTRIBUTE_PATH = create_attribute_path_from_attribute(\n   107→    0, Clusters.ThreadNetworkDiagnostics.Attributes.RoutingRole\n   108→)\n   109→DESCRIPTOR_PARTS_LIST_ATTRIBUTE_PATH = create_attribute_path_from_attribute(\n   110→    0, Clusters.Descriptor.Attributes.PartsList\n   111→)\n   112→BASIC_INFORMATION_VENDOR_ID_ATTRIBUTE_PATH = create_attribute_path_from_attribute(\n   113→    0, Clusters.BasicInformation.Attributes.VendorID\n   114→)\n   115→BASIC_INFORMATION_PRODUCT_ID_ATTRIBUTE_PATH = create_attribute_path_from_attribute(\n   116→    0, Clusters.BasicInformation.Attributes.ProductID\n   117→)\n   118→BASIC_INFORMATION_SOFTWARE_VERSION_ATTRIBUTE_PATH = (\n   119→    create_attribute_path_from_attribute(\n   120→        0, Clusters.BasicInformation.Attributes.SoftwareVersion\n   121→    )\n   122→)\n   123→BASIC_INFORMATION_SOFTWARE_VERSION_STRING_ATTRIBUTE_PATH = (\n   124→    create_attribute_path_from_attribute(\n   125→        0, Clusters.BasicInformation.Attributes.SoftwareVersionString\n   126→    )\n   127→)\n   128→ICD_ATTR_LIST_ATTRIBUTE_PATH = create_attribute_path_from_attribute(\n   129→    0, Clusters.IcdManagement.Attributes.AttributeList\n   130→)\n   131→\n   132→RE_MDNS_SERVICE_NAME = re.compile(\n   133→    rf\"^([0-9A-Fa-f]{{16}})-([0-9A-Fa-f]{{16}})\\.{re.escape(MDNS_TYPE_OPERATIONAL_NODE)}$\"\n   134→)\n   135→\n   136→\n   137→# pylint: disable=too-many-lines,too-many-instance-attributes,too-many-public-methods\n   138→\n   139→\n   140→class MatterDeviceController:\n   141→    \"\"\"Class that manages the Matter devices.\"\"\"\n   142→\n   143→    def __init__(\n   144→        self,\n   145→        server: MatterServer,\n   146→        paa_root_cert_dir: Path,\n   147→        ota_provider_dir: Path,\n   148→    ):\n   149→        \"\"\"Initialize the device controller.\"\"\"\n   150→        self.server = server\n   151→        self._ota_provider_dir = ota_provider_dir\n   152→\n   153→        self._chip_device_controller = ChipDeviceControllerWrapper(\n   154→            server, paa_root_cert_dir\n   155→        )\n   156→\n   157→        # we keep the last events in memory so we can include them in the diagnostics dump\n   158→        self.event_history: deque[Attribute.EventReadResult] = deque(maxlen=25)\n   159→        self._compressed_fabric_id: int | None = None\n   160→        self._wifi_credentials_set: bool = False\n   161→        self._thread_credentials_set: bool = False\n   162→        self._setup_node_tasks = dict[int, asyncio.Task]()\n   163→        self._nodes_in_ota: set[int] = set()\n   164→        self._node_last_seen_on_mdns: dict[int, float] = {}\n   165→        self._nodes: dict[int, MatterNodeData] = {}\n   166→        self._last_known_ip_addresses: dict[int, list[str]] = {}\n   167→        self._resubscription_attempt: dict[int, int] = {}\n   168→        self._first_resubscribe_attempt: dict[int, float] = {}\n   169→        self._known_commissioning_params: dict[int, CommissioningParameters] = {}\n   170→        self._known_commissioning_params_timers: dict[int, asyncio.TimerHandle] = {}\n   171→        self._aiobrowser: AsyncServiceBrowser | None = None\n   172→        self._aiozc: AsyncZeroconf | None = None\n   173→        self._thread_node_setup_throttle = asyncio.Semaphore(5)\n   174→        self._mdns_event_timer: dict[str, asyncio.TimerHandle] = {}\n   175→        self._polled_attributes: dict[int, set[str]] = {}\n   176→        self._custom_attribute_poller_timer: asyncio.TimerHandle | None = None\n   177→        self._custom_attribute_poller_task: asyncio.Task | None = None\n   178→        self._attribute_update_callbacks: dict[int, list[Callable]] = {}\n   179→        self._default_fabric_label: str | None = None\n   180→\n   181→    async def initialize(self) -> None:\n   182→        \"\"\"Initialize the device controller.\"\"\"\n   183→        self._compressed_fabric_id = (\n   184→            await self._chip_device_controller.get_compressed_fabric_id()\n   185→        )\n   186→        await load_local_updates(self._ota_provider_dir)\n   187→\n   188→    async def start(self) -> None:\n   189→        \"\"\"Handle logic on controller start.\"\"\"\n   190→        # load nodes from persistent storage\n   191→        nodes: dict[str, dict | None] = self.server.storage.get(DATA_KEY_NODES, {})\n   192→        orphaned_nodes: set[str] = set()\n   193→        for node_id_str, node_dict in nodes.items():\n   194→            node_id = int(node_id_str)\n   195→            if node_dict is None:\n   196→                # Non-initialized (left-over) node from a failed commissioning attempt.\n   197→                # NOTE: This code can be removed in a future version\n   198→                # as this can no longer happen.\n   199→                orphaned_nodes.add(node_id_str)\n   200→                continue\n   201→            try:\n   202→                node = dataclass_from_dict(MatterNodeData, node_dict, strict=True)\n   203→            except (KeyError, ValueError):\n   204→                # constructing MatterNodeData from the cached dict is not possible,\n   205→                # revert to a fallback object and the node will be re-interviewed\n   206→                node = MatterNodeData(\n   207→                    node_id=node_id,\n   208→                    date_commissioned=node_dict.get(\n   209→                        \"date_commissioned\",\n   210→                        datetime(1970, 1, 1),\n   211→                    ),\n   212→                    last_interview=node_dict.get(\n   213→                        \"last_interview\",\n   214→                        datetime(1970, 1, 1),\n   215→                    ),\n   216→                    interview_version=0,\n   217→                )\n   218→            # always mark node as unavailable at startup until subscriptions are ready\n   219→            node.available = False\n   220→            self._nodes[node_id] = node\n   221→        # cleanup orhpaned nodes from storage\n   222→        for node_id_str in orphaned_nodes:\n   223→            self.server.storage.remove(DATA_KEY_NODES, node_id_str)\n   224→        LOGGER.info(\"Loaded %s nodes from stored configuration\", len(self._nodes))\n   225→        # set-up mdns browser\n   226→        self._aiozc = AsyncZeroconf(ip_version=IPVersion.All)\n   227→        services = [MDNS_TYPE_OPERATIONAL_NODE, MDNS_TYPE_COMMISSIONABLE_NODE]\n   228→        self._aiobrowser = AsyncServiceBrowser(\n   229→            self._aiozc.zeroconf,\n   230→            services,\n   231→            handlers=[self._on_mdns_service_state_change],\n   232→            question_type=DNSQuestionType.QM,\n   233→        )\n   234→\n   235→    async def stop(self) -> None:\n   236→        \"\"\"Handle logic on server stop.\"\"\"\n   237→        # shutdown (and cleanup) mdns browser\n   238→        if self._aiobrowser:\n   239→            await self._aiobrowser.async_cancel()\n   240→        if self._aiozc:\n   241→            await self._aiozc.async_close()\n   242→        # Ensure any in-progress setup tasks are cancelled\n   243→        for task in self._setup_node_tasks.values():\n   244→            task.cancel()\n   245→\n   246→        # shutdown the sdk device controller\n   247→        await self._chip_device_controller.shutdown()\n   248→        LOGGER.debug(\"Stopped.\")\n   249→\n   250→    @property\n   251→    def compressed_fabric_id(self) -> int:\n   252→        \"\"\"Return the compressed fabric id.\"\"\"\n   253→        if self._compressed_fabric_id is None:\n   254→            raise RuntimeError(\"Compressed Fabric ID not set\")\n   255→        return self._compressed_fabric_id\n   256→\n   257→    @property\n   258→    def wifi_credentials_set(self) -> bool:\n   259→        \"\"\"Return if WiFi credentials have been set.\"\"\"\n   260→        return self._wifi_credentials_set\n   261→\n   262→    @property\n   263→    def thread_credentials_set(self) -> bool:\n   264→        \"\"\"Return if Thread operational dataset as been set.\"\"\"\n   265→        return self._thread_credentials_set\n   266→\n   267→    @cached_property\n   268→    def _loop(self) -> asyncio.AbstractEventLoop:\n   269→        \"\"\"Return the event loop.\"\"\"\n   270→        assert self.server.loop\n   271→        return self.server.loop\n   272→\n   273→    @lru_cache(maxsize=1024)  # noqa: B019\n   274→    def get_node_logger(\n   275→        self, logger: logging.Logger, node_id: int\n   276→    ) -> logging.LoggerAdapter:\n   277→        \"\"\"Return a logger for a specific node.\"\"\"\n   278→        return logging.LoggerAdapter(logger, {\"node\": node_id})\n   279→\n   280→    @api_command(APICommand.GET_NODES)\n   281→    def get_nodes(self, only_available: bool = False) -> list[MatterNodeData]:\n   282→        \"\"\"Return all Nodes known to the server.\"\"\"\n   283→        return [\n   284→            x\n   285→            for x in self._nodes.values()\n   286→            if x is not None and (x.available or not only_available)\n   287→        ]\n   288→\n   289→    @api_command(APICommand.GET_NODE)\n   290→    def get_node(self, node_id: int) -> MatterNodeData:\n   291→        \"\"\"Return info of a single Node.\"\"\"\n   292→        if node := self._nodes.get(node_id):\n   293→            return node\n   294→        raise NodeNotExists(f\"Node {node_id} does not exist or is not yet interviewed\")\n   295→\n   296→    @api_command(APICommand.SET_DEFAULT_FABRIC_LABEL)\n   297→    async def set_default_fabric_label(self, label: str | None) -> None:\n   298→        \"\"\"Set the default fabric label.\"\"\"\n   299→        if label is not None and len(label) > 32:\n   300→            LOGGER.info(\n   301→                \"Fabric label '%s' exceeds 32 characters, truncating to '%s'\",\n   302→                label,\n   303→                label[:32],\n   304→            )\n   305→            label = label[:32]\n   306→        self._default_fabric_label = label\n   307→\n   308→    @api_command(APICommand.COMMISSION_WITH_CODE)\n   309→    async def commission_with_code(\n   310→        self, code: str, network_only: bool = False\n   311→    ) -> MatterNodeData:\n   312→        \"\"\"\n   313→        Commission a device using a QR Code or Manual Pairing Code.\n   314→\n   315→        :param code: The QR Code or Manual Pairing Code for device commissioning.\n   316→        :param network_only: If True, restricts device discovery to network only.\n   317→\n   318→        :return: The NodeInfo of the commissioned device.\n   319→        \"\"\"\n   320→        if not network_only and not self.server.bluetooth_enabled:\n   321→            raise NodeCommissionFailed(\"Bluetooth commissioning is not available.\")\n   322→\n   323→        node_id = self._get_next_node_id()\n   324→        LOGGER.info(\n   325→            \"Starting Matter commissioning with code using Node ID %s.\",\n   326→            node_id,\n   327→        )\n   328→        try:\n   329→            commissioned_node_id: int = (\n   330→                await self._chip_device_controller.commission_with_code(\n   331→                    node_id,\n   332→                    code,\n   333→                    DiscoveryType.DISCOVERY_NETWORK_ONLY\n   334→                    if network_only\n   335→                    else DiscoveryType.DISCOVERY_ALL,\n   336→                )\n   337→            )\n   338→            # We use SDK default behavior which always uses the commissioning Node ID in the\n   339→            # generated NOC. So this should be the same really.\n   340→            LOGGER.info(\"Commissioned Node ID: %s vs %s\", commissioned_node_id, node_id)\n   341→            if commissioned_node_id != node_id:\n   342→                raise RuntimeError(\"Returned Node ID must match requested Node ID\")\n   343→        except ChipStackError as err:\n   344→            raise NodeCommissionFailed(\n   345→                f\"Commission with code failed for node {node_id}.\"\n   346→            ) from err\n   347→\n   348→        LOGGER.info(\"Matter commissioning of Node ID %s successful.\", node_id)\n   349→\n   350→        # perform full (first) interview of the device\n   351→        # we retry the interview max 3 times as it may fail in noisy\n   352→        # RF environments (in case of thread), mdns trouble or just flaky devices.\n   353→        # retrying both the mdns resolve and (first) interview, increases the chances\n   354→        # of a successful device commission.\n   355→        retries = 3\n   356→        while retries:\n   357→            try:\n   358→                await self._interview_node(node_id)\n   359→            except (NodeNotResolving, NodeInterviewFailed) as err:\n   360→                if retries <= 0:\n   361→                    try:\n   362→                        await self._chip_device_controller.unpair_device(node_id)\n   363→                    except ChipStackError as err_unpair:\n   364→                        LOGGER.warning(\n   365→                            \"Removing current fabric from device failed: %s\", err_unpair\n   366→                        )\n   367→                    raise err\n   368→                retries -= 1\n   369→                LOGGER.warning(\"Unable to interview Node %s: %s\", node_id, err)\n   370→                await asyncio.sleep(5)\n   371→            else:\n   372→                break\n   373→\n   374→        # make sure we start a subscription for this newly added node\n   375→        if task := self._setup_node_create_task(node_id):\n   376→            await task\n   377→        LOGGER.info(\"Commissioning of Node ID %s completed.\", node_id)\n   378→        # return full node object once we're complete\n   379→        return self.get_node(node_id)\n   380→\n   381→    @api_command(APICommand.COMMISSION_ON_NETWORK)\n   382→    async def commission_on_network(\n   383→        self,\n   384→        setup_pin_code: int,\n   385→        filter_type: int = 0,\n   386→        filter: Any = None,  # pylint: disable=redefined-builtin\n   387→        ip_addr: str | None = None,\n   388→    ) -> MatterNodeData:\n   389→        \"\"\"\n   390→        Do the routine for OnNetworkCommissioning, with a filter for mDNS discovery.\n   391→\n   392→        The filter can be an integer,\n   393→        a string or None depending on the actual type of selected filter.\n   394→\n   395→        NOTE: For advanced usecases only, use `commission_with_code`\n   396→        for regular commissioning.\n   397→\n   398→        Returns full NodeInfo once complete.\n   399→        \"\"\"\n   400→        node_id = self._get_next_node_id()\n   401→        if ip_addr is not None:\n   402→            ip_addr = self.server.scope_ipv6_lla(ip_addr)\n   403→\n   404→        try:\n   405→            if ip_addr is None:\n   406→                # regular CommissionOnNetwork if no IP address provided\n   407→                LOGGER.info(\n   408→                    \"Starting Matter commissioning on network using Node ID %s.\",\n   409→                    node_id,\n   410→                )\n   411→                commissioned_node_id = (\n   412→                    await self._chip_device_controller.commission_on_network(\n   413→                        node_id, setup_pin_code, filter_type, filter\n   414→                    )\n   415→                )\n   416→            else:\n   417→                LOGGER.info(\n   418→                    \"Starting Matter commissioning using Node ID %s and IP %s.\",\n   419→                    node_id,\n   420→                    ip_addr,\n   421→                )\n   422→                commissioned_node_id = await self._chip_device_controller.commission_ip(\n   423→                    node_id, setup_pin_code, ip_addr\n   424→                )\n   425→            # We use SDK default behavior which always uses the commissioning Node ID in the\n   426→            # generated NOC. So this should be the same really.\n   427→            if commissioned_node_id != node_id:\n   428→                raise RuntimeError(\"Returned Node ID must match requested Node ID\")\n   429→        except ChipStackError as err:\n   430→            raise NodeCommissionFailed(\n   431→                f\"Commissioning failed for node {node_id}.\"\n   432→            ) from err\n   433→\n   434→        LOGGER.info(\"Matter commissioning of Node ID %s successful.\", node_id)\n   435→\n   436→        # perform full (first) interview of the device\n   437→        # we retry the interview max 3 times as it may fail in noisy\n   438→        # RF environments (in case of thread), mdns trouble or just flaky devices.\n   439→        # retrying both the mdns resolve and (first) interview, increases the chances\n   440→        # of a successful device commission.\n   441→        retries = 3\n   442→        while retries:\n   443→            try:\n   444→                await self._interview_node(node_id)\n   445→            except NodeInterviewFailed as err:\n   446→                if retries <= 0:\n   447→                    raise err\n   448→                retries -= 1\n   449→                LOGGER.warning(\"Unable to interview Node %s: %s\", node_id, err)\n   450→                await asyncio.sleep(5)\n   451→            else:\n   452→                break\n   453→        # make sure we start a subscription for this newly added node\n   454→        if task := self._setup_node_create_task(node_id):\n   455→            await task\n   456→        LOGGER.info(\"Commissioning of Node ID %s completed.\", node_id)\n   457→        # return full node object once we're complete\n   458→        return self.get_node(node_id)\n   459→\n   460→    @api_command(APICommand.SET_WIFI_CREDENTIALS)\n   461→    async def set_wifi_credentials(self, ssid: str, credentials: str) -> None:\n   462→        \"\"\"Set WiFi credentials for commissioning to a (new) device.\"\"\"\n   463→\n   464→        await self._chip_device_controller.set_wifi_credentials(ssid, credentials)\n   465→        self._wifi_credentials_set = True\n   466→        self.server.signal_event(EventType.SERVER_INFO_UPDATED, self.server.get_info())\n   467→\n   468→    @api_command(APICommand.SET_THREAD_DATASET)\n   469→    async def set_thread_operational_dataset(self, dataset: str) -> None:\n   470→        \"\"\"Set Thread Operational dataset in the stack.\"\"\"\n   471→\n   472→        await self._chip_device_controller.set_thread_operational_dataset(dataset)\n   473→        self._thread_credentials_set = True\n   474→        self.server.signal_event(EventType.SERVER_INFO_UPDATED, self.server.get_info())\n   475→\n   476→    @api_command(APICommand.OPEN_COMMISSIONING_WINDOW)\n   477→    async def open_commissioning_window(\n   478→        self,\n   479→        node_id: int,\n   480→        timeout: int = 300,  # noqa: ASYNC109 timeout parameter required for native timeout\n   481→        iteration: int = 1000,\n   482→        option: int = ChipDeviceController.CommissioningWindowPasscode.kTokenWithRandomPin,\n   483→        discriminator: int | None = None,\n   484→    ) -> CommissioningParameters:\n   485→        \"\"\"Open a commissioning window to commission a device present on this controller to another.\n   486→\n   487→        Returns code to use as discriminator.\n   488→        \"\"\"\n   489→        if (node := self._nodes.get(node_id)) is None or not node.available:\n   490→            raise NodeNotReady(f\"Node {node_id} is not (yet) available.\")\n   491→\n   492→        read_response: Attribute.AsyncReadTransaction.ReadResponse = (\n   493→            await self._chip_device_controller.read_attribute(\n   494→                node_id,\n   495→                [(0, Clusters.AdministratorCommissioning.Attributes.WindowStatus)],\n   496→            )\n   497→        )\n   498→        window_status = cast(\n   499→            Clusters.AdministratorCommissioning.Enums.CommissioningWindowStatusEnum,\n   500→            read_response.attributes[0][Clusters.AdministratorCommissioning][\n   501→                Clusters.AdministratorCommissioning.Attributes.WindowStatus\n   502→            ],\n   503→        )\n   504→\n   505→        if (\n   506→            window_status\n   507→            == Clusters.AdministratorCommissioning.Enums.CommissioningWindowStatusEnum.kWindowNotOpen\n   508→        ):\n   509→            # Commissioning window is no longer open (e.g. device got paired already)\n   510→            # Remove our stored commissioning parameters.\n   511→            if node_id in self._known_commissioning_params_timers:\n   512→                self._known_commissioning_params_timers[node_id].cancel()\n   513→            self._known_commissioning_params.pop(node_id, None)\n   514→        else:\n   515→            # Node is still in commissioning mode, return previous parameters\n   516→            if node_id in self._known_commissioning_params:\n   517→                return self._known_commissioning_params[node_id]\n   518→\n   519→            # We restarted or somebody else put node into commissioning mode\n   520→            # Close commissioning window and put into commissioning mode again.\n   521→            LOGGER.info(\n   522→                \"Commissioning window open but no parameters available. Closing and reopening commissioning window for node %s\",\n   523→                node_id,\n   524→            )\n   525→            await self._chip_device_controller.send_command(\n   526→                node_id,\n   527→                endpoint_id=0,\n   528→                command=Clusters.AdministratorCommissioning.Commands.RevokeCommissioning(),\n   529→                timed_request_timeout_ms=5000,\n   530→            )\n   531→\n   532→        if discriminator is None:\n   533→            discriminator = secrets.randbelow(2**12)\n   534→\n   535→        sdk_result = await self._chip_device_controller.open_commissioning_window(\n   536→            node_id,\n   537→            timeout,\n   538→            iteration,\n   539→            discriminator,\n   540→            option,\n   541→        )\n   542→        self._known_commissioning_params[node_id] = params = CommissioningParameters(\n   543→            setup_pin_code=sdk_result.setupPinCode,\n   544→            setup_manual_code=sdk_result.setupManualCode,\n   545→            setup_qr_code=sdk_result.setupQRCode,\n   546→        )\n   547→        # we store the commission parameters and clear them after the timeout\n   548→        self._known_commissioning_params_timers[node_id] = self._loop.call_later(\n   549→            timeout, self._known_commissioning_params.pop, node_id, None\n   550→        )\n   551→        return params\n   552→\n   553→    @api_command(APICommand.DISCOVER)\n   554→    async def discover_commissionable_nodes(\n   555→        self,\n   556→    ) -> list[CommissionableNodeData]:\n   557→        \"\"\"Discover Commissionable Nodes (discovered on BLE or mDNS).\"\"\"\n   558→        sdk_result = await self._chip_device_controller.discover_commissionable_nodes()\n   559→        if sdk_result is None:\n   560→            return []\n   561→        # ensure list\n   562→        if not isinstance(sdk_result, list):\n   563→            sdk_result = [sdk_result]\n   564→        return [\n   565→            CommissionableNodeData(\n   566→                instance_name=x.instanceName,\n   567→                host_name=x.hostName,\n   568→                port=x.port,\n   569→                long_discriminator=x.longDiscriminator,\n   570→                vendor_id=x.vendorId,\n   571→                product_id=x.productId,\n   572→                commissioning_mode=x.commissioningMode,\n   573→                device_type=x.deviceType,\n   574→                device_name=x.deviceName,\n   575→                pairing_instruction=x.pairingInstruction,\n   576→                pairing_hint=x.pairingHint,\n   577→                mrp_retry_interval_idle=x.mrpRetryIntervalIdle,\n   578→                mrp_retry_interval_active=x.mrpRetryIntervalActive,\n   579→                # TCP is provisional, so no devices out there anyway\n   580→                supports_tcp=False,\n   581→                addresses=x.addresses,\n   582→                rotating_id=x.rotatingId,\n   583→            )\n   584→            for x in sdk_result\n   585→        ]\n   586→\n   587→    async def _interview_node(self, node_id: int) -> None:\n   588→        try:\n   589→            LOGGER.info(\"Interviewing node: %s\", node_id)\n   590→            read_response: Attribute.AsyncReadTransaction.ReadResponse = (\n   591→                await self._chip_device_controller.read_attribute(\n   592→                    node_id,\n   593→                    [()],\n   594→                    fabric_filtered=False,\n   595→                )\n   596→            )\n   597→        except ChipStackError as err:\n   598→            raise NodeInterviewFailed(f\"Failed to interview node {node_id}\") from err\n   599→\n   600→        # Set label if specified and needed\n   601→        if self._default_fabric_label:\n   602→            cluster = read_response.attributes[0][Clusters.OperationalCredentials]\n   603→            fabrics: list[\n   604→                Clusters.OperationalCredentials.Structs.FabricDescriptorStruct\n   605→            ] = cluster[Clusters.OperationalCredentials.Attributes.Fabrics]\n   606→            fabric_index = cluster[\n   607→                Clusters.OperationalCredentials.Attributes.CurrentFabricIndex\n   608→            ]\n   609→\n   610→            local_fabric = next(\n   611→                (fabric for fabric in fabrics if fabric.fabricIndex == fabric_index),\n   612→                None,\n   613→            )\n   614→            if local_fabric and local_fabric.label != self._default_fabric_label:\n   615→                try:\n   616→                    LOGGER.debug(\n   617→                        \"Setting fabric label for node %s to '%s'\",\n   618→                        node_id,\n   619→                        self._default_fabric_label,\n   620→                    )\n   621→                    await self._chip_device_controller.send_command(\n   622→                        node_id,\n   623→                        0,\n   624→                        Clusters.OperationalCredentials.Commands.UpdateFabricLabel(\n   625→                            self._default_fabric_label\n   626→                        ),\n   627→                    )\n   628→                except ChipStackError as err:\n   629→                    LOGGER.warning(\n   630→                        \"Failed to set fabric label for node %s: %s\", node_id, err\n   631→                    )\n   632→\n   633→        is_new_node = node_id not in self._nodes\n   634→        existing_info = self._nodes.get(node_id)\n   635→        node = MatterNodeData(\n   636→            node_id=node_id,\n   637→            date_commissioned=(\n   638→                existing_info.date_commissioned if existing_info else datetime.utcnow()\n   639→            ),\n   640→            last_interview=datetime.utcnow(),\n   641→            interview_version=DATA_MODEL_SCHEMA_VERSION,\n   642→            available=existing_info.available if existing_info else False,\n   643→            attributes=parse_attributes_from_read_result(read_response.tlvAttributes),\n   644→        )\n   645→\n   646→        if existing_info:\n   647→            node.attribute_subscriptions = existing_info.attribute_subscriptions\n   648→        # work out if the node is a bridge device by looking at the devicetype of endpoint 1\n   649→        if attr_data := node.attributes.get(\"1/29/0\"):\n   650→            node.is_bridge = any(x[0] == 14 for x in attr_data)\n   651→\n   652→        # save updated node data\n   653→        self._nodes[node_id] = node\n   654→        self._write_node_state(node_id, True)\n   655→        if is_new_node:\n   656→            # new node - first interview\n   657→            self.server.signal_event(EventType.NODE_ADDED, node)\n   658→        else:\n   659→            # existing node, signal node updated event\n   660→            # TODO: maybe only signal this event if attributes actually changed ?\n   661→            self.server.signal_event(EventType.NODE_UPDATED, node)\n   662→\n   663→        LOGGER.debug(\"Interview of node %s completed\", node_id)\n   664→\n   665→    @api_command(APICommand.INTERVIEW_NODE)\n   666→    async def interview_node(self, node_id: int) -> None:\n   667→        \"\"\"Interview a node.\"\"\"\n   668→        if node_id >= TEST_NODE_START:\n   669→            LOGGER.debug(\n   670→                \"interview_node called for test node %s\",\n   671→                node_id,\n   672→            )\n   673→            self.server.signal_event(EventType.NODE_UPDATED, self._nodes[node_id])\n   674→            return\n   675→\n   676→        await self._interview_node(node_id)\n   677→\n   678→        if self._default_fabric_label:\n   679→            await self._chip_device_controller.send_command(\n   680→                node_id,\n   681→                0,\n   682→                Clusters.OperationalCredentials.Commands.UpdateFabricLabel(\n   683→                    self._default_fabric_label\n   684→                ),\n   685→            )\n   686→\n   687→    @api_command(APICommand.DEVICE_COMMAND)\n   688→    async def send_device_command(\n   689→        self,\n   690→        node_id: int,\n   691→        endpoint_id: int,\n   692→        cluster_id: int,\n   693→        command_name: str,\n   694→        payload: dict,\n   695→        response_type: Any | None = None,\n   696→        timed_request_timeout_ms: int | None = None,\n   697→        interaction_timeout_ms: int | None = None,\n   698→    ) -> Any:\n   699→        \"\"\"Send a command to a Matter node/device.\"\"\"\n   700→        if (node := self._nodes.get(node_id)) is None or not node.available:\n   701→            raise NodeNotReady(f\"Node {node_id} is not (yet) available.\")\n   702→        cluster_cls: Cluster = ALL_CLUSTERS[cluster_id]\n   703→        command_cls = getattr(cluster_cls.Commands, command_name)\n   704→        command = dataclass_from_dict(command_cls, payload, allow_sdk_types=True)\n   705→        if node_id >= TEST_NODE_START:\n   706→            LOGGER.debug(\n   707→                \"send_device_command called for test node %s on endpoint_id: %s - \"\n   708→                \"cluster_id: %s - command_name: %s - payload: %s\\n%s\",\n   709→                node_id,\n   710→                endpoint_id,\n   711→                cluster_id,\n   712→                command_name,\n   713→                payload,\n   714→                command,\n   715→            )\n   716→            return None\n   717→        return await self._chip_device_controller.send_command(\n   718→            node_id,\n   719→            endpoint_id,\n   720→            command,\n   721→            response_type,\n   722→            timed_request_timeout_ms,\n   723→            interaction_timeout_ms,\n   724→        )\n   725→\n   726→    @api_command(APICommand.READ_ATTRIBUTE)\n   727→    async def read_attribute(\n   728→        self,\n   729→        node_id: int,\n   730→        attribute_path: str | list[str],\n   731→        fabric_filtered: bool = False,\n   732→    ) -> dict[str, Any]:\n   733→        \"\"\"\n   734→        Read one or more attribute(s) on a node by specifying an attributepath.\n   735→\n   736→        The attribute path can be a single string or a list of strings.\n   737→        The attribute path may contain wildcards (*) for cluster and/or attribute id.\n   738→\n   739→        The return type is a dictionary with the attribute path as key and the value as value.\n   740→        \"\"\"\n   741→        if (node := self._nodes.get(node_id)) is None or not node.available:\n   742→            raise NodeNotReady(f\"Node {node_id} is not (yet) available.\")\n   743→        attribute_paths = (\n   744→            attribute_path if isinstance(attribute_path, list) else [attribute_path]\n   745→        )\n   746→\n   747→        # handle test node\n   748→        if node_id >= TEST_NODE_START:\n   749→            LOGGER.debug(\n   750→                \"read_attribute called for test node %s on path(s): %s - fabric_filtered: %s\",\n   751→                node_id,\n   752→                str(attribute_paths),\n   753→                fabric_filtered,\n   754→            )\n   755→            return {\n   756→                attr_path: self._nodes[node_id].attributes.get(attr_path)\n   757→                for attr_path in attribute_paths\n   758→            }\n   759→\n   760→        LOGGER.debug(\n   761→            \"read_attribute called for node %s on path(s): %s - fabric_filtered: %s\",\n   762→            node_id,\n   763→            str(attribute_paths),\n   764→            fabric_filtered,\n   765→        )\n   766→        # parse text based attribute paths into the SDK Attribute Path objects\n   767→        attributes: list[Attribute.AttributePath] = []\n   768→        for attr_path in attribute_paths:\n   769→            endpoint_id, cluster_id, attribute_id = parse_attribute_path(attr_path)\n   770→            attributes.append(\n   771→                Attribute.AttributePath(\n   772→                    EndpointId=endpoint_id,\n   773→                    ClusterId=cluster_id,\n   774→                    AttributeId=attribute_id,\n   775→                )\n   776→            )\n   777→\n   778→        result = await self._chip_device_controller.read(\n   779→            node_id,\n   780→            attributes,\n   781→            fabric_filtered,\n   782→        )\n   783→        read_atributes = parse_attributes_from_read_result(result.tlvAttributes)\n   784→        # update cached info in node attributes and signal events for updated attributes\n   785→        values_changed = False\n   786→        for attr_path, value in read_atributes.items():\n   787→            if node.attributes.get(attr_path) != value:\n   788→                node.attributes[attr_path] = value\n   789→                self.server.signal_event(\n   790→                    EventType.ATTRIBUTE_UPDATED,\n   791→                    # send data as tuple[node_id, attribute_path, new_value]\n   792→                    (node_id, attr_path, value),\n   793→                )\n   794→\n   795→                values_changed = True\n   796→        # schedule writing of the node state if any values changed\n   797→        if values_changed:\n   798→            self._write_node_state(node_id)\n   799→        return read_atributes\n   800→"}]},"uuid":"03110c3a-f5c1-48b0-97a9-1959479124b4","timestamp":"2026-04-05T04:28:47.502Z"},"type":"agent_progress","prompt":"","agentId":"a8cfb461256633736"},"toolUseID":"agent_msg_0162hX3uehmwnogfj3FQYhXY","parentToolUseID":"toolu_01G6sAuwJzUhPn9wBmY6dvqS","uuid":"2fffa062-25ea-4797-97ee-c872e9e4313d","timestamp":"2026-04-05T04:28:47.502Z","userType":"external","entrypoint":"cli","cwd":"/Users/raman/projects/lock_code_manager","sessionId":"3f097ff1-5bb6-4622-8cfe-35782dd270ba","version":"2.1.81","gitBranch":"fix/matter-duplicate-code-handling","slug":"jolly-wandering-moonbeam"}
